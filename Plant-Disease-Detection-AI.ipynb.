ooling2D(),\n","  layers.Dense(128, activation='relu'),\n","  layers.Dropout(0.2),\n","  layers.Dense(5, activation='softmax') # 5 classes for example\n","])\n","\n","model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])\n","\n","# 4. Training (Simulated for 5 epochs for speed)\n","history = model.fit(train_ds, validation_data=val_ds, epochs=5)\n","\n","# 5. Save Results\n","model.save('plant_disease_model.h5')\n","print(\"Model Trained and Saved Successfully!\")"]},{"cell_type":"code","source":["# خلية لعرض صورة واختبار توقع الموديل عليها\n","import numpy as np\n","\n","# أخذ عينة من بيانات التحقق\n","image_batch, label_batch = next(iter(val_ds))\n","predictions = model.predict(image_batch)\n","score = tf.nn.softmax(predictions[0])\n","\n","# عرض الصورة والنتيجة\n","plt.figure(figsize=(6, 6))\n","plt.imshow(image_batch[0].numpy().astype(\"uint8\"))\n","plt.title(f\"Prediction: {np.argmax(score)} (Confidence: {100 * np.max(score):.2f}%)\")\n","plt.axis(\"off\")\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":339},"id":"1-U9KziRDEUI","executionInfo":{"status":"ok","timestamp":1776959655409,"user_tz":-180,"elapsed":11616,"user":{"displayName":"سما عمار","userId":"15749215158894942932"}},"outputId":"a6eaaa9b-4a05-4490-baf2-2701e18560c4"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m7s\u001b[0m 7s/step\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import numpy as np\n","\n","# 1. تحديد أسماء الأصناف (تأكدي من مطابقتها للفولدرات عندج)\n","class_names = train_ds.class_names\n","\n","# 2. أخذ وجبة صور من بيانات التحقق\n","plt.figure(figsize=(12, 12))\n","for images, labels in val_ds.take(1):\n","    predictions = model.predict(i